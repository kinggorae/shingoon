---
import { getEntry, render } from 'astro:content';
import Base from '../layouts/Base.astro';
import Article from '../components/Article.astro';

const entry = await getEntry('pages', 'about');
if (!entry) throw new Error('about.md not found');
const { Content } = await render(entry);
---

<Base title={`${entry.data.title} — 신군닷컴`} description={entry.data.summary}>
  <Article eyebrow="ABOUT" tags={entry.data.tags} backHref="/" backLabel="홈">
    <Content />
  </Article>
</Base>
