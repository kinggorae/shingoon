---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import { CATEGORIES } from '../../lib/categories';

const posts = (await getCollection('posts')).sort(
  (a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime()
);

// 클라이언트 점수기에 넘길 글 데이터
const postsData = posts.map((p) => ({
  slug: p.id.replace(/\/index$/, ''),
  title: p.data.title,
  description: p.data.description,
  category: p.data.category ?? '',
  tags: (p.data.tags ?? []).join(', '),
  tldr: (p.data.tldr ?? []).join('\n'),
  faqCount: (p.data.faqs ?? []).length,
  body: p.body ?? '',
}));

const catOptions = Object.entries(CATEGORIES);
---

<Base title="GEO 점수판 — 신군닷컴" description="글이 AI 검색·검색엔진에 잘 노출되는지 실시간으로 점검하는 도구.">
  <meta slot="head" name="robots" content="noindex" />

  <section class="section">
    <div class="container">
      <div class="head">
        <p class="eyebrow">EDITOR TOOL</p>
        <h1 class="section-title">실시간 GEO 점수판</h1>
        <p class="section-desc">발행된 글을 불러오거나 초안을 입력하면, AI 검색(GEO)·SEO 관점 점수와 개선 포인트를 실시간으로 보여줍니다.</p>
      </div>

      <div class="geo-grid">
        <!-- 입력 -->
        <div class="geo-form">
          <label class="fld">
            <span class="fld-label">발행된 글 불러오기</span>
            <select id="loader">
              <option value="">— 새 초안 —</option>
              {postsData.map((p) => <option value={p.slug}>{p.title}</option>)}
            </select>
          </label>

          <label class="fld">
            <span class="fld-label">제목</span>
            <input id="f-title" type="text" placeholder="질문형·구체형 제목을 권장" />
          </label>

          <label class="fld">
            <span class="fld-label">메타 설명 (SEO·GEO)</span>
            <textarea id="f-desc" rows="2" placeholder="검색·AI 미리보기에 쓰일 한 문장 (120~160자 권장)"></textarea>
          </label>

          <div class="fld-row">
            <label class="fld">
              <span class="fld-label">카테고리</span>
              <select id="f-cat">
                <option value="">미지정</option>
                {catOptions.map(([v, l]) => <option value={v}>{l}</option>)}
              </select>
            </label>
            <label class="fld">
              <span class="fld-label">태그 (쉼표로 구분)</span>
              <input id="f-tags" type="text" placeholder="GEO, 동물병원" />
            </label>
          </div>

          <div class="fld-row">
            <label class="fld">
              <span class="fld-label">핵심 요약 (TL;DR) — 한 줄에 하나</span>
              <textarea id="f-tldr" rows="3" placeholder="AI가 인용하기 좋은 요약을 한 줄씩"></textarea>
            </label>
            <label class="fld fld-narrow">
              <span class="fld-label">FAQ 개수</span>
              <input id="f-faq" type="number" min="0" value="0" />
            </label>
          </div>

          <label class="fld">
            <span class="fld-label">본문 (마크다운)</span>
            <textarea id="f-body" rows="10" placeholder="## 소제목 으로 구조화하고, 첫 문단에서 바로 답하세요."></textarea>
          </label>
        </div>

        <!-- 점수 -->
        <aside class="geo-score">
          <div class="ring-wrap">
            <svg viewBox="0 0 120 120" class="ring">
              <circle cx="60" cy="60" r="52" class="ring-bg" />
              <circle cx="60" cy="60" r="52" class="ring-fg" id="ring-fg" />
            </svg>
            <div class="ring-center">
              <span class="ring-score" id="score-num">0</span>
              <span class="ring-max">/ 100</span>
            </div>
          </div>
          <p class="score-grade" id="score-grade">입력을 시작하세요</p>
          <ul class="checklist" id="checklist"></ul>
        </aside>
      </div>
    </div>
  </section>

  <script type="application/json" id="posts-data" set:html={JSON.stringify(postsData).replace(/</g, '\\u003c')} />
</Base>

<style>
  .head { display: flex; flex-direction: column; gap: 10px; margin-bottom: 32px; }
  .geo-grid { display: grid; grid-template-columns: 1.1fr 0.9fr; gap: 28px; align-items: start; }

  .geo-form { display: flex; flex-direction: column; gap: 16px; }
  .fld { display: flex; flex-direction: column; gap: 7px; }
  .fld-row { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
  .fld-narrow { max-width: 120px; }
  .fld-label { font-size: 12.5px; font-weight: 700; color: var(--text-2); }
  .geo-form input, .geo-form textarea, .geo-form select {
    width: 100%; background: var(--surface); border: 1px solid var(--border); border-radius: var(--r-md);
    color: var(--text); padding: 11px 13px; font: inherit; font-size: 14px; transition: border-color 0.15s ease;
  }
  .geo-form textarea { resize: vertical; line-height: 1.6; }
  .geo-form input:focus, .geo-form textarea:focus, .geo-form select:focus {
    outline: none; border-color: var(--accent); box-shadow: 0 0 0 3px var(--accent-soft);
  }

  .geo-score {
    position: sticky; top: 88px; padding: 26px 24px; border: 1px solid var(--border); border-radius: var(--r-lg);
    background: linear-gradient(180deg, rgba(255,255,255,0.035), rgba(255,255,255,0.01));
  }
  .ring-wrap { position: relative; width: 168px; height: 168px; margin: 0 auto 8px; }
  .ring { width: 100%; height: 100%; transform: rotate(-90deg); }
  .ring-bg { fill: none; stroke: var(--border); stroke-width: 9; }
  .ring-fg {
    fill: none; stroke: var(--accent); stroke-width: 9; stroke-linecap: round;
    stroke-dasharray: 326.7; stroke-dashoffset: 326.7; transition: stroke-dashoffset 0.5s ease, stroke 0.3s ease;
  }
  .ring-center { position: absolute; inset: 0; display: flex; flex-direction: column; align-items: center; justify-content: center; }
  .ring-score { font-size: 2.6rem; font-weight: 800; letter-spacing: -0.04em; line-height: 1; }
  .ring-max { font-size: 12px; color: var(--text-3); font-family: var(--mono); margin-top: 2px; }
  .score-grade { text-align: center; font-weight: 700; font-size: 0.95rem; margin-bottom: 18px; color: var(--text-2); }

  .checklist { display: flex; flex-direction: column; gap: 9px; }
  .check { display: flex; gap: 10px; align-items: flex-start; font-size: 13.5px; line-height: 1.5; }
  .check-ic { flex-shrink: 0; width: 18px; height: 18px; border-radius: 50%; display: grid; place-items: center; font-size: 11px; font-weight: 800; margin-top: 1px; }
  .check.pass .check-ic { background: rgba(52,211,153,0.18); color: var(--ok); }
  .check.warn .check-ic { background: rgba(251,191,36,0.18); color: var(--warn); }
  .check.fail .check-ic { background: rgba(248,113,113,0.16); color: #f87171; }
  .check-body strong { color: var(--text); font-weight: 700; }
  .check-tip { color: var(--text-3); font-size: 12.5px; margin-top: 2px; }

  @media (max-width: 820px) {
    .geo-grid { grid-template-columns: 1fr; }
    .geo-score { position: static; }
  }
</style>

<script>
  const $ = (id) => document.getElementById(id);
  const posts = JSON.parse($('posts-data').textContent || '[]');
  const fields = ['title', 'desc', 'cat', 'tags', 'tldr', 'faq', 'body'];

  // 발행 글 불러오기
  $('loader').addEventListener('change', (e) => {
    const p = posts.find((x) => x.slug === e.target.value);
    if (!p) {
      ['f-title', 'f-desc', 'f-tags', 'f-tldr', 'f-body'].forEach((id) => ($(id).value = ''));
      $('f-cat').value = ''; $('f-faq').value = '0';
    } else {
      $('f-title').value = p.title || '';
      $('f-desc').value = p.description || '';
      $('f-cat').value = p.category || '';
      $('f-tags').value = p.tags || '';
      $('f-tldr').value = p.tldr || '';
      $('f-faq').value = String(p.faqCount || 0);
      $('f-body').value = p.body || '';
    }
    score();
  });

  function analyze() {
    const title = $('f-title').value.trim();
    const desc = $('f-desc').value.trim();
    const cat = $('f-cat').value;
    const tags = $('f-tags').value.split(',').map((t) => t.trim()).filter(Boolean);
    const tldr = $('f-tldr').value.split('\n').map((t) => t.trim()).filter(Boolean);
    const faq = parseInt($('f-faq').value, 10) || 0;
    const body = $('f-body').value;
    const bodyLen = body.replace(/\s/g, '').length;
    const h2 = (body.match(/^##\s+/gm) || []).length;
    const specific = /[?？0-9]|법|방법|이유|하는/.test(title);

    const items = [];
    let score = 0;
    const add = (pts, max, label, tip) => {
      const status = pts >= max ? 'pass' : pts > 0 ? 'warn' : 'fail';
      items.push({ status, label, tip: status === 'pass' ? '' : tip });
      score += pts;
    };

    // 1. 제목 (15)
    add(
      (title ? 5 : 0) + (title.length >= 18 && title.length <= 60 ? 5 : title ? 2 : 0) + (specific ? 5 : 0),
      15, `제목 (${title.length}자)`,
      !title ? '제목을 입력하세요.' : title.length > 60 ? '60자 이내로 줄이면 노출에 유리합니다.' : title.length < 18 ? '조금 더 구체적인 제목을 권장합니다.' : '숫자·질문형 등 구체 표현을 더해보세요.'
    );
    // 2. 메타 설명 (20)
    add(
      (desc ? 6 : 0) + (desc.length >= 70 && desc.length <= 160 ? 14 : desc ? 6 : 0),
      20, `메타 설명 (${desc.length}자)`,
      !desc ? '메타 설명을 입력하세요.' : desc.length > 160 ? '160자 이내로 줄이세요(잘림 방지).' : '70~160자로 핵심을 한 문장에 담으세요.'
    );
    // 3. TL;DR (18)
    add(
      (tldr.length >= 1 ? 9 : 0) + (tldr.length >= 2 ? 9 : 0),
      18, `핵심 요약 (${tldr.length}개)`,
      tldr.length === 0 ? 'AI가 인용하기 좋은 핵심 요약을 2줄 이상 추가하세요.' : 'TL;DR을 2개 이상 권장합니다.'
    );
    // 4. FAQ (18)
    add(
      (faq >= 1 ? 6 : 0) + (faq >= 3 ? 12 : faq >= 1 ? 6 : 0),
      18, `FAQ (${faq}개)`,
      faq === 0 ? 'FAQ는 AI 답변 인용에 매우 강력합니다. 3개 이상 추가하세요.' : 'FAQ를 3개 이상 권장합니다.'
    );
    // 5. 본문 구조 (19)
    add(
      (h2 >= 2 ? 9 : h2 === 1 ? 4 : 0) + (bodyLen >= 600 ? 10 : bodyLen >= 300 ? 5 : 0),
      19, `본문 구조 (H2 ${h2}개 · ${bodyLen}자)`,
      h2 < 2 ? '## 소제목을 2개 이상 두어 구조화하세요.' : bodyLen < 600 ? '본문을 600자 이상으로 채우세요.' : ''
    );
    // 6. 태그·카테고리 (10)
    add(
      (tags.length >= 2 ? 5 : tags.length === 1 ? 2 : 0) + (cat ? 5 : 0),
      10, `태그·카테고리 (태그 ${tags.length}개)`,
      tags.length < 2 ? '관련 키워드 태그를 2개 이상 다세요.' : !cat ? '카테고리를 지정하세요.' : ''
    );

    return { score: Math.round(score), items };
  }

  function score() {
    const { score, items } = analyze();
    const ring = $('ring-fg');
    const C = 326.7;
    ring.style.strokeDashoffset = String(C - (C * score) / 100);
    const color = score >= 80 ? 'var(--ok)' : score >= 50 ? 'var(--warn)' : '#f87171';
    ring.style.stroke = color;
    $('score-num').textContent = String(score);
    const grade = score >= 80 ? 'GEO 최적 — 발행 준비 완료' : score >= 50 ? '보강하면 더 잘 노출됩니다' : '핵심 요소가 빠졌습니다';
    $('score-grade').textContent = grade;
    $('checklist').innerHTML = items
      .map((it) => {
        const ic = it.status === 'pass' ? '✓' : it.status === 'warn' ? '!' : '×';
        const tip = it.tip ? `<div class="check-tip">${it.tip}</div>` : '';
        return `<li class="check ${it.status}"><span class="check-ic">${ic}</span><div class="check-body"><strong>${it.label}</strong>${tip}</div></li>`;
      })
      .join('');
  }

  ['f-title', 'f-desc', 'f-cat', 'f-tags', 'f-tldr', 'f-faq', 'f-body'].forEach((id) =>
    $(id).addEventListener('input', score)
  );
  score();
</script>
