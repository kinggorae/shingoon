---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import { categoryLabel } from '../lib/categories';

const WORK_ORDER = ['brand-commerce-growth', 'global-export', 'animal-hospital-mso', 'human-hospital-marketing'];
const work = (await getCollection('work')).sort(
  (a, b) => WORK_ORDER.indexOf(a.id) - WORK_ORDER.indexOf(b.id)
);
const services = (await getCollection('services')).sort(
  (a, b) => (b.data.date?.getTime() ?? 0) - (a.data.date?.getTime() ?? 0)
);
const posts = (await getCollection('posts'))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime())
  .slice(0, 3);

const fmt = (date) =>
  new Intl.DateTimeFormat('ko-KR', { year: 'numeric', month: 'long', day: 'numeric' }).format(date);
const postHref = (id) => `/blog/${id.replace(/\/index$/, '')}`;

// 업무 가능 국가
const countries = [
  { code: 'kr', name: '한국' },
  { code: 'vn', name: '베트남' },
  { code: 'sg', name: '싱가포르' },
  { code: 'cn', name: '중국' },
  { code: 'jp', name: '일본' },
];
---

<Base>
  <!-- HERO -->
  <section class="hero">
    <div class="container hero-grid">
      <div class="hero-copy">
        <p class="eyebrow">RYAN SHIN · 신군</p>
        <h1 class="hero-title">
          만들고, 띄우고,<br />
          <span class="grad-text">기록한다.</span>
        </h1>
        <p class="hero-tagline">
          비즈니스 바다를 항해한 지 <strong>20년</strong> — 그래도 난 아직,
          최고의 <strong>동료(나카마)</strong>와 <strong>보물</strong>을 찾아 모험 중이다! 🏴‍☠️
        </p>
        <p class="hero-sub">연쇄 창업가 신현규 · 서울에서 사이공까지, 비즈니스가 내 모험.</p>
        <div class="hero-actions">
          <a href="/blog" class="btn btn-primary">최신 글 보기 →</a>
          <a href="/about" class="btn btn-ghost">신군은 누구인가</a>
        </div>
      </div>
      <div class="hero-visual">
        <span class="hero-visual-glow" aria-hidden="true"></span>
        <img class="hero-luffy" src="/luffy.jpg" alt="모험을 떠나는 신군 — 밀짚모자를 쓴 루피처럼" width="554" height="832" />
      </div>
    </div>
    <div class="container">
      <div class="hero-reach">
        <p class="reach-lead">
          스무 해 동안 일곱 번 창업했고, 지금은 여섯 개의 서비스를 운영합니다.
          일은 한 항구에 머물지 않아서 — <strong>다섯 나라의 바다</strong>를 오갑니다.
        </p>
        <ul class="flags" aria-label="업무 가능 국가">
          {countries.map((c) => (
            <li>
              <img src={`/flags/${c.code}.svg`} alt="" width="26" height="18" loading="lazy" />
              <span>{c.name}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
    <div class="hero-glow" aria-hidden="true"></div>
  </section>

  <!-- LATEST POSTS (BLOG) -->
  {posts.length > 0 && (
    <section class="section" id="blog">
      <div class="container">
        <div class="head head-row">
          <div>
            <p class="eyebrow">BLOG</p>
            <h2 class="section-title">최신 글</h2>
          </div>
          <a href="/blog" class="head-link">전체 글 보기 →</a>
        </div>
        <div class="blog-grid">
          {posts.map((p) => (
            <a href={postHref(p.id)} class="card post-card">
              {p.data.cover && (
                <img class="post-card-cover" src={p.data.cover} alt="" width="640" height="360" loading="lazy" />
              )}
              <div class="post-card-body">
                <div class="row">
                  {p.data.category && <span class="badge">{categoryLabel(p.data.category)}</span>}
                  <time class="post-card-date" datetime={p.data.publishDate.toISOString()}>{fmt(p.data.publishDate)}</time>
                </div>
                <h3 class="post-card-title">{p.data.title}</h3>
                <p class="card-summary">{p.data.description}</p>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- MAIN WORK / FOCUS -->
  <section class="section section-tight" id="work">
    <div class="container">
      <div class="head">
        <p class="eyebrow">MAIN WORK</p>
        <h2 class="section-title">지금 메인으로 하는 일</h2>
        <p class="section-desc">한국 브랜드를 국내에서 잘 팔리게, 또 해외로 내보내고 — 동물병원을 키우고, 그 모델을 사람병원으로 넓힌다.</p>
      </div>
      <div class="work-grid">
        {work.map((w, i) => (
          <a href={`/work/${w.id}`} class="card work-card">
            <span class="work-num">{String(i + 1).padStart(2, '0')}</span>
            <div class="row">
              {w.data.status && <span class="badge">{w.data.status}</span>}
            </div>
            <h3 class="work-title">{w.data.title.split(' — ')[0]}</h3>
            <p class="card-summary">{w.data.summary}</p>
            <span class="card-link">자세히 보기 →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- SERVICES -->
  <section class="section section-tight" id="services">
    <div class="container">
      <div class="head">
        <p class="eyebrow">SERVICES</p>
        <h2 class="section-title">하고 있는 일</h2>
        <p class="section-desc">현재 운영·런칭 중인 서비스들. 자료가 모이는 대로 계속 채워집니다.</p>
      </div>
      <div class="grid grid-3">
        {services.map((s) => (
          <a href={`/services/${s.id}`} class="card service-card">
            <div class="row">
              {s.data.company && <span class="badge">{s.data.company}</span>}
              {s.data.status && <span class="badge ok">{s.data.status}</span>}
            </div>
            <h3 class="card-title">{s.data.title.split(' — ')[0]}</h3>
            <p class="card-summary">{s.data.summary}</p>
          </a>
        ))}
      </div>
    </div>
  </section>
</Base>

<style>
  /* Hero */
  .hero { position: relative; padding-block: clamp(56px, 10vw, 116px) clamp(40px, 7vw, 72px); overflow: hidden; }
  .hero-grid {
    position: relative; z-index: 1;
    display: grid; grid-template-columns: 1.05fr 0.95fr; gap: clamp(24px, 5vw, 56px); align-items: center;
  }
  .hero-copy { min-width: 0; }
  .hero-title {
    font-size: clamp(2.4rem, 6.5vw, 4.6rem); font-weight: 800; letter-spacing: -0.045em;
    line-height: 1.05; margin-top: 20px; word-break: keep-all;
  }
  .hero-tagline {
    margin-top: 26px; max-width: 32ch; font-size: clamp(1.05rem, 1.7vw, 1.3rem);
    line-height: 1.65; color: var(--text); word-break: keep-all;
  }
  .hero-tagline strong { color: var(--accent-2); font-weight: 800; }
  .hero-sub { margin-top: 14px; font-size: 14px; color: var(--text-3); word-break: keep-all; }
  .hero-actions { display: flex; gap: 12px; margin-top: 30px; flex-wrap: wrap; }

  /* Luffy visual */
  .hero-visual { position: relative; display: flex; justify-content: center; align-items: center; min-width: 0; }
  .hero-visual-glow {
    position: absolute; width: 80%; height: 80%; border-radius: 50%;
    background: radial-gradient(circle, rgba(91,140,255,0.28), rgba(34,211,238,0.12) 45%, transparent 70%);
    filter: blur(36px); z-index: 0;
  }
  .hero-luffy {
    position: relative; z-index: 1; width: 100%; max-width: 420px; height: auto; border-radius: var(--r-xl);
    border: 1px solid var(--border-2); box-shadow: 0 30px 70px rgba(0,0,0,0.5);
    animation: heroFloat 5s ease-in-out infinite;
  }
  @keyframes heroFloat { 0%,100% { transform: translateY(0); } 50% { transform: translateY(-12px); } }
  .hero-reach {
    margin-top: clamp(40px, 6vw, 56px); padding-top: 28px; border-top: 1px solid var(--border);
  }
  .reach-lead {
    max-width: 58ch; font-size: clamp(1rem, 1.5vw, 1.18rem); line-height: 1.75; color: var(--text-2); word-break: keep-all;
  }
  .reach-lead strong { color: var(--text); font-weight: 700; }
  .flags { display: flex; flex-wrap: wrap; gap: 10px 20px; margin-top: 22px; }
  .flags li { display: inline-flex; align-items: center; gap: 8px; font-size: 14.5px; font-weight: 600; color: var(--text); }
  .flags img { width: 26px; height: auto; border-radius: 3px; box-shadow: 0 1px 5px rgba(0, 0, 0, 0.45); display: block; }
  .hero-glow {
    position: absolute; top: -20%; right: -10%; width: 50rem; height: 50rem; z-index: 0;
    background: radial-gradient(circle, rgba(91, 140, 255, 0.18), transparent 60%);
    filter: blur(30px); pointer-events: none;
  }

  /* Section heads */
  .head { display: flex; flex-direction: column; gap: 10px; margin-bottom: 34px; }
  .head-row { flex-direction: row; align-items: flex-end; justify-content: space-between; gap: 16px; }
  .head-link { font-size: 14px; font-weight: 700; color: var(--accent-2); white-space: nowrap; }
  .head-link:hover { color: #67e8f9; }
  .section-tight { padding-top: 0; }

  /* Blog cards */
  .blog-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 18px; }
  .post-card { display: flex; flex-direction: column; padding: 0; overflow: hidden; }
  .post-card-cover { width: 100%; aspect-ratio: 16 / 9; object-fit: cover; border-bottom: 1px solid var(--border); }
  .post-card-body { padding: 22px 22px 24px; display: flex; flex-direction: column; }
  .post-card-date { font-size: 12px; color: var(--text-3); font-family: var(--mono); }
  .post-card-title { font-size: 1.18rem; font-weight: 800; letter-spacing: -0.02em; line-height: 1.35; margin-top: 12px; word-break: keep-all; }
  .post-card:hover .post-card-title { color: #fff; }

  /* Main work cards */
  .work-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 18px; }
  .work-card { padding: 30px 28px; }
  .work-num {
    font-family: var(--mono); font-size: 13px; font-weight: 700; letter-spacing: 0.1em;
    color: var(--accent-2); opacity: 0.8;
  }
  .work-title { font-size: 1.5rem; font-weight: 800; letter-spacing: -0.03em; margin-top: 14px; line-height: 1.3; }
  .work-card .row { margin-top: 12px; }
  .work-card .card-summary { font-size: 1rem; }

  /* Grids */
  .grid { display: grid; gap: 18px; }
  .grid-3 { grid-template-columns: repeat(3, 1fr); }

  .row { display: flex; align-items: center; gap: 8px; flex-wrap: wrap; }
  .card-title { font-size: 1.2rem; font-weight: 800; letter-spacing: -0.02em; }
  .card-summary { color: var(--text-2); font-size: 0.95rem; margin-top: 12px; line-height: 1.7; word-break: keep-all; }
  .card-link { display: inline-block; margin-top: 16px; font-size: 13.5px; font-weight: 700; color: var(--accent-2); }
  .service-card .card-title { margin-top: 16px; }

  @media (max-width: 960px) {
    .work-grid { grid-template-columns: 1fr; }
    .blog-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 860px) {
    .grid-3 { grid-template-columns: repeat(2, 1fr); }
    .hero-grid { grid-template-columns: 1fr; gap: 30px; }
    .hero-visual { order: -1; justify-content: center; }
    .hero-luffy { max-width: 300px; }
    .hero-tagline { max-width: none; }
  }
  @media (max-width: 600px) {
    .grid-3, .blog-grid { grid-template-columns: 1fr; }
  }
</style>
