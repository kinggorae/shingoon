---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';
import { categoryLabel } from '../../lib/categories';

const postSlug = (id) => id.replace(/\/index$/, '');

export async function getStaticPaths() {
  const posts = (await getCollection('posts')).filter((p) => !p.data.draft);
  return posts.map((entry) => ({
    params: { slug: entry.id.replace(/\/index$/, '') },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content, headings } = await render(entry);
const d = entry.data;
const slug = postSlug(entry.id);

const toc = headings.filter((h) => h.depth === 2 || h.depth === 3);

// 읽기 시간 (한글 기준 대략 분당 500자)
const minutes = Math.max(1, Math.round((entry.body?.length ?? 0) / 500));

const fmt = (date) =>
  new Intl.DateTimeFormat('ko-KR', { year: 'numeric', month: 'long', day: 'numeric' }).format(date);
const iso = (date) => date.toISOString();

const canonical = new URL(`/blog/${slug}`, Astro.site).toString();
const published = iso(d.publishDate);
const modified = iso(d.updatedDate ?? d.publishDate);

// ── GEO/SEO 구조화 데이터 (JSON-LD) ──
const articleLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: d.title,
  description: d.description,
  datePublished: published,
  dateModified: modified,
  author: { '@type': 'Person', name: d.author },
  publisher: { '@type': 'Organization', name: '신군닷컴', url: 'https://shingoon.com' },
  mainEntityOfPage: { '@type': 'WebPage', '@id': canonical },
  keywords: d.tags.join(', '),
  inLanguage: 'ko-KR',
};
const faqLd = d.faqs.length
  ? {
      '@context': 'https://schema.org',
      '@type': 'FAQPage',
      mainEntity: d.faqs.map((f) => ({
        '@type': 'Question',
        name: f.question,
        acceptedAnswer: { '@type': 'Answer', text: f.answer },
      })),
    }
  : null;
const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: '홈', item: 'https://shingoon.com/' },
    { '@type': 'ListItem', position: 2, name: '블로그', item: 'https://shingoon.com/blog' },
    { '@type': 'ListItem', position: 3, name: d.title, item: canonical },
  ],
};
if (d.cover) {
  articleLd.image = new URL(d.cover, Astro.site).toString();
}
const jsonLd = [articleLd, breadcrumbLd, ...(faqLd ? [faqLd] : [])];
const coverUrl = d.cover ? new URL(d.cover, Astro.site).toString() : null;
---

<Base title={`${d.title} — 신군닷컴`} description={d.description}>
  {jsonLd.map((obj) => (
    <script
      slot="head"
      type="application/ld+json"
      set:html={JSON.stringify(obj).replace(/</g, '\\u003c')}
    />
  ))}
  <meta slot="head" property="og:type" content="article" />
  <meta slot="head" property="article:published_time" content={published} />
  {coverUrl && <meta slot="head" property="og:image" content={coverUrl} />}
  {coverUrl && <meta slot="head" name="twitter:image" content={coverUrl} />}

  <article class="post container">
    <a href="/blog" class="back">← 블로그</a>

    <header class="post-head">
      <div class="post-tags">
        {d.category && <span class="badge">{categoryLabel(d.category)}</span>}
        {d.tags.map((t) => <span class="tag">#{t}</span>)}
      </div>
      <h1 class="post-title">{d.title}</h1>
      <p class="post-desc">{d.description}</p>
      <div class="post-meta">
        <span>{d.author}</span>
        <span>·</span>
        <time datetime={published}>{fmt(d.publishDate)}</time>
        <span>·</span>
        <span>약 {minutes}분</span>
      </div>
    </header>

    {coverUrl && (
      <img class="post-cover" src={d.cover} alt={d.title} width="1200" height="630" loading="eager" />
    )}

    {d.tldr.length > 0 && (
      <aside class="tldr" aria-label="핵심 요약">
        <p class="tldr-label">핵심 요약 (TL;DR)</p>
        <ul>
          {d.tldr.map((t) => <li>{t}</li>)}
        </ul>
      </aside>
    )}

    {toc.length > 1 && (
      <nav class="toc" aria-label="목차">
        <p class="toc-label">목차</p>
        <ol>
          {toc.map((h) => (
            <li class:list={[{ sub: h.depth === 3 }]}>
              <a href={`#${h.slug}`}>{h.text}</a>
            </li>
          ))}
        </ol>
      </nav>
    )}

    <div class="prose">
      <Content />
    </div>

    {d.faqs.length > 0 && (
      <section class="faq" aria-label="자주 묻는 질문">
        <h2 class="faq-title">자주 묻는 질문</h2>
        {d.faqs.map((f) => (
          <details class="faq-item">
            <summary>{f.question}</summary>
            <p>{f.answer}</p>
          </details>
        ))}
      </section>
    )}
  </article>
</Base>

<style>
  .post { max-width: 760px; padding-block: clamp(34px, 5vw, 56px); }
  .back { display: inline-block; font-size: 14px; font-weight: 600; color: var(--text-2); margin-bottom: 22px; }
  .back:hover { color: var(--accent-2); }
  .post-head { padding-bottom: 26px; border-bottom: 1px solid var(--border); }
  .post-tags { display: flex; gap: 7px; flex-wrap: wrap; margin-bottom: 16px; }
  .post-title { font-size: clamp(2rem, 4.5vw, 2.9rem); font-weight: 800; letter-spacing: -0.035em; line-height: 1.2; word-break: keep-all; }
  .post-desc { margin-top: 16px; color: var(--text-2); font-size: 1.08rem; line-height: 1.7; word-break: keep-all; }
  .post-meta { display: flex; gap: 8px; align-items: center; margin-top: 18px; font-size: 13.5px; color: var(--text-3); font-family: var(--mono); flex-wrap: wrap; }

  .post-cover {
    width: 100%; aspect-ratio: 1200 / 630; object-fit: cover;
    margin-top: 30px; border-radius: var(--r-lg); border: 1px solid var(--border);
  }
  .tldr {
    margin-top: 30px; padding: 22px 24px; border-radius: var(--r-lg);
    background: var(--grad-soft); border: 1px solid rgba(91, 140, 255, 0.22);
  }
  .tldr-label { font-size: 12px; font-weight: 800; letter-spacing: 0.1em; text-transform: uppercase; color: var(--accent-2); font-family: var(--mono); margin-bottom: 12px; }
  .tldr ul { display: flex; flex-direction: column; gap: 8px; }
  .tldr li { position: relative; padding-left: 1.4em; color: var(--text); line-height: 1.7; word-break: keep-all; }
  .tldr li::before { content: "→"; position: absolute; left: 0; color: var(--accent); font-weight: 800; }

  .toc { margin-top: 26px; padding: 18px 22px; border: 1px solid var(--border); border-radius: var(--r-md); background: rgba(255, 255, 255, 0.02); }
  .toc-label { font-size: 11px; font-weight: 800; letter-spacing: 0.08em; text-transform: uppercase; color: var(--text-3); font-family: var(--mono); margin-bottom: 10px; }
  .toc ol { list-style: none; padding: 0; display: flex; flex-direction: column; gap: 6px; }
  .toc li.sub { padding-left: 16px; }
  .toc a { font-size: 14.5px; color: var(--text-2); }
  .toc a:hover { color: var(--accent-2); }

  .prose { margin-top: 34px; }

  .faq { margin-top: 44px; padding-top: 30px; border-top: 1px solid var(--border); }
  .faq-title { font-size: 1.4rem; font-weight: 800; letter-spacing: -0.02em; margin-bottom: 18px; }
  .faq-item { border: 1px solid var(--border); border-radius: var(--r-md); padding: 0 18px; margin-bottom: 10px; background: rgba(255, 255, 255, 0.02); transition: border-color 0.2s ease; }
  .faq-item[open] { border-color: rgba(91, 140, 255, 0.35); }
  .faq-item summary { cursor: pointer; padding: 16px 0; font-weight: 700; list-style: none; display: flex; justify-content: space-between; align-items: center; gap: 12px; word-break: keep-all; }
  .faq-item summary::-webkit-details-marker { display: none; }
  .faq-item summary::after { content: "+"; color: var(--accent-2); font-size: 1.3rem; font-weight: 400; flex-shrink: 0; transition: transform 0.2s ease; }
  .faq-item[open] summary::after { transform: rotate(45deg); }
  .faq-item p { padding: 0 0 18px; color: var(--text-2); line-height: 1.8; word-break: keep-all; }
</style>
