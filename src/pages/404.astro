---
import Base from '../layouts/Base.astro';
---

<Base title="페이지를 찾을 수 없습니다 — 신군닷컴" description="요청하신 페이지가 없습니다.">
  <section class="nf">
    <div class="container">
      <p class="nf-code grad-text">404</p>
      <h1 class="nf-title">페이지를 찾을 수 없어요</h1>
      <p class="nf-desc">주소가 바뀌었거나, 아직 없는 페이지일 수 있어요.</p>
      <div class="nf-actions">
        <a href="/" class="btn btn-primary">홈으로 →</a>
        <a href="/blog" class="btn btn-ghost">블로그 보기</a>
      </div>
    </div>
  </section>
</Base>

<style>
  .nf { padding-block: clamp(80px, 16vw, 180px); text-align: center; }
  .nf-code { font-size: clamp(4rem, 14vw, 8rem); font-weight: 800; letter-spacing: -0.05em; line-height: 1; }
  .nf-title { font-size: clamp(1.5rem, 4vw, 2.2rem); font-weight: 800; letter-spacing: -0.03em; margin-top: 14px; }
  .nf-desc { color: var(--text-2); margin-top: 12px; }
  .nf-actions { display: flex; gap: 12px; justify-content: center; margin-top: 30px; flex-wrap: wrap; }
</style>
